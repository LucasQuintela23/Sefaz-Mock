{
  "name": "sefaz-mock",
  "version": "0.1.0",
  "private": true,
  "description": "Framework de testes NF-e IBS/CBS com Playwright, WireMock e ambiente local",
  "scripts": {
    "matrix:generate": "node scripts/generate-uf-matrix.js",
    "wiremock:mappings:generate": "node scripts/generate-wiremock-authorized-mapping.js",
    "batch:summary": "node scripts/generate-batch-summary.js",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test tests/integration/nfe.smoke.spec.js",
    "test:smoke:local": "bash scripts/smoke-local-node.sh",
    "test:k8s": "bash scripts/bootstrap-k8s-local.sh test",
    "k8s:up": "bash scripts/bootstrap-k8s-local.sh up",
    "k8s:down": "bash scripts/bootstrap-k8s-local.sh down",
    "k8s:logs": "bash scripts/bootstrap-k8s-local.sh logs",
    "k8s:all": "bash scripts/bootstrap-k8s-local.sh all",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.6.0"
  }
}
